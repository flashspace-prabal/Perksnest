PORT=3000

# Frontend origin(s) allowed to call this API (comma separated)
CORS_ORIGINS=http://localhost:8080,https://your-frontend.vercel.app

# Supabase (same project credentials used by frontend)
SUPABASE_URL=https://auth.perksnest.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
