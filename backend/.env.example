# Server
PORT=3000
APP_BASE_URL=http://localhost:5173

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Nodemailer SMTP
# For Gmail, use your Gmail address and an App Password, not your normal password.
EMAIL_SERVICE=gmail
EMAIL_USER=your-sender-email@gmail.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM="PerksNest <your-sender-email@gmail.com>"

# Contact form recipient. Deal/premium emails go to the logged-in user's email.
CONTACT_EMAIL_TO=admin@perksnest.com

# Optional custom SMTP instead of EMAIL_SERVICE.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
